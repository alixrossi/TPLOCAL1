@model TPLOCAL1.Models.FormModel
@{
    ViewData["Title"] = "HN - Validation";
    ViewData["Heading"] = "Formulaire d'évaluation";
    ViewData["Page"] = "ValidationForm";
}

<p><strong>Votre formulaire a bien été pris en compte</strong></p>

<!-- Informations personnelles -->
<table>
    <thead>
    <tr>
        <th colspan="2"><strong>Informations personnelles</strong></th>
    </tr>
    </thead>
    <tbody>
    <tr>
        <td>Nom</td>
        <td>@Model.LastName</td>
    </tr>
    <tr>
        <td>Prénom</td>
        <td>@Model.FirstName</td>
    </tr>
    <tr>
        <td>Sexe</td>
        <td>@Model.Sex</td>
    </tr>
    <tr>
        <td>Adresse</td>
        <td>@Model.Address</td>
    </tr>
    <tr>
        <td>Code postal</td>
        <td>@Model.PostCode</td>
    </tr>
    <tr>
        <td>Ville</td>
        <td>@Model.City</td>
    </tr>
    <tr>
        <td>Adresse mail</td>
        <td>@Model.Email</td>
    </tr>
    </tbody>
</table>

<!-- Informations formation suivie -->
<table>
    <thead>
    <tr>
        <th colspan="2"><strong>Informations formation suivie</strong></th>
    </tr>
    </thead>
    <tbody>
    <tr>
        <td>Date début formation</td>
        <td>@Model.StartDate?.ToString("dd/MM/yyyy")</td>
    </tr>
    <tr>
        <td>Formation suivie</td>
        <td>@Model.Formation</td>
    </tr>
    </tbody>
</table>

<!-- Avis sur la formation -->
<table>
    <thead>
    <tr>
        <th colspan="2"><strong>Avis sur la formation</strong></th>
    </tr>
    </thead>
    <tbody>
    <tr>
        <td>Formation Cobol</td>
        <td>@Model.OpinionCobol</td>
    </tr>
    <tr>
        <td>Formation C#</td>
        <td>@Model.OpinionCSharp</td>
    </tr>
    </tbody>
</table>
