@model TPLOCAL1.Models.FormModel

<!DOCTYPE html>
<html>
<head>
    <title>HN - Validation</title>
    <link rel="stylesheet" href="~/resources/Index.css" />
</head>
<body>
    <header>
        <img src="~/resources/GroupeHN.png" class="image" alt="GroupeHN" />
        <h1>Formulaire d'évaluation</h1>
    </header>

    <nav>
        <ul>
            <li><a href="/Home/Index">Accueil</a></li>
            <li><a href="/Home/Index/OpinionList">Liste avis</a></li>
        </ul>
    </nav>

    <section>
        <p style="text-align:center;"><strong>Votre formulaire a bien été pris en compte</strong></p>

        <!-- Informations personnelles -->
        <table>
            <tr>
                <td colspan="2"><strong>Informations personnelles</strong></td>
            </tr>
            <tr>
                <td>Nom</td>
                <td>@Model.Nom</td>
            </tr>
            <tr>
                <td>Prénom</td>
                <td>@Model.Prenom</td>
            </tr>
            <tr>
                <td>Sexe</td>
                <td>@Model.Sexe</td>
            </tr>
            <tr>
                <td>Adresse</td>
                <td>@Model.Adresse</td>
            </tr>
            <tr>
                <td>Code postal</td>
                <td>@Model.CodePostal</td>
            </tr>
            <tr>
                <td>Ville</td>
                <td>@Model.Ville</td>
            </tr>
            <tr>
                <td>Adresse mail</td>
                <td>@Model.AdresseMail</td>
            </tr>
        </table>

        <!-- Informations formation suivie -->
        <table>
            <tr>
                <td colspan="2"><strong>Informations formation suivie</strong></td>
            </tr>
            <tr>
                <td>Date début formation</td>
                <td>@Model.DateDebut?.ToString("dd/MM/yyyy")</td>
            </tr>
            <tr>
                <td>Formation suivie</td>
                <td>@Model.Formation</td>
            </tr>
        </table>

        <!-- Avis sur la formation -->
        <table>
            <tr>
                <td colspan="2"><strong>Avis sur la formation</strong></td>
            </tr>
            <tr>
                <td>Formation Cobol</td>
                <td>@Model.AvisCobol</td>
            </tr>
            <tr>
                <td>Formation C#</td>
                <td>@Model.AvisCSharp</td>
            </tr>
        </table>
    </section>
</body>
</html>
