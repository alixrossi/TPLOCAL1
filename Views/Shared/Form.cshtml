@model TPLOCAL1.Models.FormModel

<!DOCTYPE html>
<html>
<head>
    <title>HN - Formulaire</title>
    <link rel="stylesheet" href="~/resources/Index.css" />
</head>
<body>
    <header>
        <img src="~/resources/GroupeHN.png" class="image" alt="GroupeHN" />
        <h1>Formulaire d'évaluation</h1>
    </header>
    <nav>
        <ul>
            <li><a href="/Home/Index">Accueil</a></li>
            <li><a href="/Home/Index/OpinionList">Liste avis</a></li>
        </ul>
    </nav>
    <section>
        @Html.ValidationSummary(false, "")
        <form action="/Home/ValidationForm" method="post">
            @Html.AntiForgeryToken()
            <!-- Informations personnelles -->
            <table>
                <thead>
                <tr>
                    <th colspan="2"><strong>Informations personnelles</strong></th>
                </tr>
                </thead>
                <tbody>
                <tr>
                    <td>Nom</td>
                    <td>
                        <input asp-for="Nom" type="text" />
                        <span asp-validation-for="Nom"></span>
                    </td>
                </tr>
                <tr>
                    <td>Prénom</td>
                    <td>
                        <input asp-for="Prenom" type="text" />
                        <span asp-validation-for="Prenom"></span>
                    </td>
                </tr>
                <tr>
                    <td>Sexe</td>
                    <td>
                        <select asp-for="Sexe">
                            <option value="">Sélectionner un sexe</option>
                            <option value="Homme">Homme</option>
                            <option value="Femme">Femme</option>
                            <option value="Autre">Autre</option>
                        </select>
                        <span asp-validation-for="Sexe"></span>
                    </td>
                </tr>
                <tr>
                    <td>Adresse</td>
                    <td>
                        <input asp-for="Adresse" type="text" />
                        <span asp-validation-for="Adresse"></span>
                    </td>
                </tr>
                <tr>
                    <td>Code postal</td>
                    <td>
                        <input asp-for="CodePostal" type="text" />
                        <span asp-validation-for="CodePostal"></span>
                    </td>
                </tr>
                <tr>
                    <td>Ville</td>
                    <td>
                        <input asp-for="Ville" type="text" />
                        <span asp-validation-for="Ville"></span>
                    </td>
                </tr>
                <tr>
                    <td>Adresse mail</td>
                    <td>
                        <input asp-for="AdresseMail" type="text" />
                        <span asp-validation-for="AdresseMail"></span>
                    </td>
                </tr>
                </tbody>
            </table>
            <!-- Informations formation suivie -->
            <table>
                <thead>
                <tr>
                    <th colspan="2"><strong>Informations formation suivie</strong></th>
                </tr>
                </thead>
                <tbody>
                <tr>
                    <td>Date début formation</td>
                    <td>
                        <input asp-for="DateDebut" type="date" />
                        <span asp-validation-for="DateDebut"></span>
                    </td>
                </tr>
                <tr>
                    <td>Formation suivie</td>
                    <td>
                        <select asp-for="Formation">
                            <option value="">Sélectionner une formation</option>
                            <option value="Formation Cobol">Formation Cobol</option>
                            <option value="Formation Objet">Formation Objet</option>
                            <option value="Formation Double Compétence">Formation Double Compétence</option>
                        </select>
                        <span asp-validation-for="Formation"></span>
                    </td>
                </tr>
                </tbody>
            </table>
            <!-- Avis sur la formation -->
            <table>
                <thead>
                <tr>
                    <th colspan="2"><strong>Avis sur la formation</strong></th>
                </tr>
                </thead>
                <tbody>
                <tr>
                    <td>Formation Cobol</td>
                    <td>
                        <input asp-for="AvisCobol" type="text" />
                    </td>
                </tr>
                <tr>
                    <td>Formation C#</td>
                    <td>
                        <input asp-for="AvisCSharp" type="text" />
                    </td>
                </tr>
                </tbody>
            </table>
            <p>
                <input type="submit" value="Valider" />
            </p>
        </form>
    </section>
</body>
</html>
