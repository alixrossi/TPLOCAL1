@model TPLOCAL1.Models.FormModel
@{
    ViewData["Title"] = "HN - Formulaire";
    ViewData["Heading"] = "Formulaire d'évaluation";
    ViewData["Page"] = "Form";
}

<form asp-controller="Home" asp-action="ValidationForm" method="post">
    @Html.AntiForgeryToken()
    <!-- Informations personnelles -->
    <table>
        <thead>
        <tr>
            <th colspan="2"><strong>Informations personnelles</strong></th>
        </tr>
        </thead>
        <tbody>
        <tr>
            <td>Nom</td>
            <td>
                <input asp-for="LastName" type="text" />
                <span asp-validation-for="LastName"></span>
            </td>
        </tr>
        <tr>
            <td>Prénom</td>
            <td>
                <input asp-for="FirstName" type="text" />
                <span asp-validation-for="FirstName"></span>
            </td>
        </tr>
        <tr>
            <td>Sexe</td>
            <td>
                <select asp-for="Sex">
                    <option value="">Sélectionner un sexe</option>
                    <option value="Homme">Homme</option>
                    <option value="Femme">Femme</option>
                    <option value="Autre">Autre</option>
                </select>
                <span asp-validation-for="Sex"></span>
            </td>
        </tr>
        <tr>
            <td>Adresse</td>
            <td>
                <input asp-for="Address" type="text" />
                <span asp-validation-for="Address"></span>
            </td>
        </tr>
        <tr>
            <td>Code postal</td>
            <td>
                <input asp-for="PostCode" type="text" />
                <span asp-validation-for="PostCode"></span>
            </td>
        </tr>
        <tr>
            <td>Ville</td>
            <td>
                <input asp-for="City" type="text" />
                <span asp-validation-for="City"></span>
            </td>
        </tr>
        <tr>
            <td>Adresse mail</td>
            <td>
                <input asp-for="Email" type="text" />
                <span asp-validation-for="Email"></span>
            </td>
        </tr>
        </tbody>
    </table>
    <!-- Informations formation suivie -->
    <table>
        <thead>
        <tr>
            <th colspan="2"><strong>Informations formation suivie</strong></th>
        </tr>
        </thead>
        <tbody>
        <tr>
            <td>Date début formation</td>
            <td>
                <input asp-for="StartDate" type="date" />
                <span asp-validation-for="StartDate"></span>
            </td>
        </tr>
        <tr>
            <td>Formation suivie</td>
            <td>
                <select asp-for="Formation">
                    <option value="">Sélectionner une formation</option>
                    <option value="Formation Cobol">Formation Cobol</option>
                    <option value="Formation Objet">Formation Objet</option>
                    <option value="Formation Double Compétence">Formation Double Compétence</option>
                </select>
                <span asp-validation-for="Formation"></span>
            </td>
        </tr>
        </tbody>
    </table>
    <!-- Avis sur la formation -->
    <table>
        <thead>
        <tr>
            <th colspan="2"><strong>Avis sur la formation</strong></th>
        </tr>
        </thead>
        <tbody>
        <tr>
            <td>Formation Cobol</td>
            <td>
                <input asp-for="OpinionCobol" type="text" />
            </td>
        </tr>
        <tr>
            <td>Formation C#</td>
            <td>
                <input asp-for="OpinionCSharp" type="text" />
            </td>
        </tr>
        </tbody>
    </table>
    <p>
        <input type="submit" value="Valider" />
    </p>
</form>
